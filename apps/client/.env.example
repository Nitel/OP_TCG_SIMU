# URL du serveur Socket.IO déployé
# En local : laisser vide (fallback automatique sur http://localhost:3001)
# En production : mettre l'URL complète de votre serveur déployé
VITE_SERVER_URL=https://your-server-url

# CDN base URL for card images (Cloudflare R2 or other)
# Leave empty to serve images from local /public/card-images/ folder (dev default)
# Production: set to your R2 public URL after running `pnpm upload-to-r2`
# Example: VITE_CDN_BASE_URL=https://cdn.optcg-simu.com
VITE_CDN_BASE_URL=https://pub-75c1546f0ba24886a56b7d7b1991d3b0.r2.dev

