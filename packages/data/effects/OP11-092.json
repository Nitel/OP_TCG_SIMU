{
  "id": "OP11-092",
  "cardId": "OP11-092",
  "effectText": "[On Play] You may trash 1 card from your hand: Draw 1 card and play up to 1 {SWORD} type Character card with a cost of 8 or less other than [Helmeppo] from your trash. Then, place the 1 Character played by this effect at the bottom of the owner's deck at the end of this turn.",
  "effects": [
    {
      "trigger": "OnPlay",
      "actions": [
        {
          "type": "ForceDiscard",
          "optional": true,
          "count": 1,
          "source": "Hand",
          "thenActions": [
            {
              "type": "DrawCard",
              "count": 1
            },
            {
              "type": "PlayFromHand",
              "filter": {
                "type": "SWORD",
                "cardType": "Character",
                "maxCost": 8,
                "excludeNames": [
                  "Helmeppo"
                ]
              },
              "source": "Trash",
              "count": 1,
              "maxCount": 1
            }
          ]
        }
      ]
    },
    {
      "trigger": "EndOfTurn",
      "condition": "Always",
      "actions": [
        {
          "type": "ReturnToHand",
          "target": "LastPlayedCharacterByThisEffect",
          "destination": "BottomOfDeck"
        }
      ]
    }
  ]
}
