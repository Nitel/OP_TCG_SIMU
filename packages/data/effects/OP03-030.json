{
  "id": "OP03-030",
  "effectText": "[On Play] Look at 5 cards from the top of your deck; reveal up to 1 green {East Blue} type card other than [Nami] and add it to your hand. Then, place the rest at the bottom of your deck in any order.",
  "effects": [
    {
      "trigger": "OnPlay",
      "actions": [
        {
