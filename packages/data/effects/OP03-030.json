            "types": [
              "green",
              "East Blue"
            ],
            "excludeNames": [
              "Nami"
            ],
            "maxFromTop": 5
          },
          "count": {
            "min": 0,
            "max": 1
          },
          "destination": "hand"
        },
        {
          "type": "PlaySelf",
          "destination": "deckBottom"
        }
      ]
    }
  ]
}
